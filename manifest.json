{
  "manifest_version": 3,
  "name": "Media Scout Downloader",
  "description": "Detecta videos, audios y playlists accesibles desde la pestaña activa y permite descargarlos desde el popup.",
  "version": "0.3.0",
  "icons": {
    "16": "assets/img/icon16.png",
    "32": "assets/img/icon32.png",
    "48": "assets/img/icon48.png",
    "128": "assets/img/icon128.png"
  },
  "action": {
    "default_title": "Media Scout Downloader",
    "default_popup": "src/ui/popup.html",
    "default_icon": {
      "16": "assets/img/icon16.png",
      "32": "assets/img/icon32.png"
    }
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "options_page": "src/options/options.html",
  "permissions": [
    "downloads",
    "scripting",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/contentScanner.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
